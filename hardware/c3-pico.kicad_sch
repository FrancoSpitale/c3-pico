(text "Native USB on IO18/IO19 (not broken out - use the USB-C connector).\nUART0 (IO20/IO21) on the right header for classic serial." (exclude_from_sim no) (at 40.64 163.83 0) (effects (font (size 1.6 1.6)) (justify left bottom)) (uuid "90cd0598-d349-4aad-8ec9-81573a3c3cab"))
(text "Strapping: IO9 = BOOT (hold low + reset for download mode).\nIO8 pulled up (required high for serial download); doubles as user LED." (exclude_from_sim no) (at 40.64 170.18 0) (effects (font (size 1.6 1.6)) (justify left bottom)) (uuid "a1769c99-0e8c-4cfb-b9e9-f83d9dd75874"))
(text "CC1/CC2: 5.1k pulldowns -> board enumerates as USB device (UFP)\non any USB-C host or charger." (exclude_from_sim no) (at 40.64 176.53 0) (effects (font (size 1.6 1.6)) (justify left bottom)) (uuid "c79c8f3e-ff2b-436a-baa3-2d59eea3945d"))
